<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="turbo-root" content="{{ path('app_home') }}">
    <title>{% block title %}Portfolio{% endblock %}</title>
    
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow" style="background-color: #252526 !important;">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">Portfolio</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_projects') }}">Projets</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_contact') }}">Contact</a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link btn btn-success ms-2" href="{{ path('app_admin') }}">Admin</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-danger ms-2" href="{{ path('app_logout') }}">Déconnexion</a>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-primary ms-2" href="{{ path('app_login') }}">Connexion</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    {% block body %}{% endblock %}

    <footer class="text-white text-center py-4 mt-5" style="background-color: #1e1e1e;">
        <div class="container">
            <p>&copy; {{ "now"|date("Y") }} Portfolio - Tous droits réservés</p>
        </div>
    </footer>
</body>
</html>
