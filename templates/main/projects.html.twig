{% extends 'base.html.twig' %}

{% block title %}Projets - Portfolio{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-5 text-center">Mes Projets</h1>

    <div class="row">
        {% for project in projects %}
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    {% if project.getImages()|length > 0 %}
                        <img src="{{ project.getImages()[0] }}" class="card-img-top" alt="{{ project.title }}" style="height: 200px; object-fit: cover;">
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">{{ project.title }}</h5>
                        <p class="card-text flex-grow-1">{{ project.description|slice(0, 150) }}...</p>
                        
                        <div class="mb-3">
                            {% for tech in project.getTechnologies() %}
                                <span class="badge bg-secondary me-1">{{ tech }}</span>
                            {% endfor %}
                        </div>
                        
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_project_detail', {id: project.id}) }}" class="btn btn-success flex-grow-1">Détails</a>
                            {% if project.githubLink %}
                                <a href="{{ project.githubLink }}" target="_blank" class="btn btn-outline-dark">
                                    <i class="bi bi-github"></i> GitHub
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <p class="text-center text-muted">Aucun projet pour le moment.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
