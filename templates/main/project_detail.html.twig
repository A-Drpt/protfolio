{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} - Portfolio{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-4">{{ project.title }}</h1>

    {% if project.images|length > 0 %}
        <div id="projectCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
            <div class="carousel-inner">
                {% for image in project.images %}
                    <div class="carousel-item {% if loop.first %}active{% endif %}">
                        <img src="{{ image }}" class="d-block w-100" alt="{{ project.title }}" style="max-height: 500px; object-fit: contain;">
                    </div>
                {% endfor %}
            </div>
            {% if project.images|length > 1 %}
                <button class="carousel-control-prev" type="button" data-bs-target="#projectCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Précédent</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#projectCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Suivant</span>
                </button>
            {% endif %}
        </div>
    {% endif %}

    <div class="row">
        <div class="col-lg-8">
            <h3>Description</h3>
            <p>{{ project.description }}</p>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Technologies utilisées</h5>
                    <div class="mb-3">
                        {% for tech in project.technologies %}
                            <span class="badge bg-primary me-1 mb-1">{{ tech }}</span>
                        {% endfor %}
                    </div>

                    <h5 class="card-title mt-4">Liens</h5>
                    <div class="d-grid gap-2">
                        {% if project.githubLink %}
                            <a href="{{ project.githubLink }}" target="_blank" class="btn btn-dark">
                                <i class="bi bi-github"></i> Voir sur GitHub
                            </a>
                        {% endif %}
                        {% if project.demoLink %}
                            <a href="{{ project.demoLink }}" target="_blank" class="btn btn-primary">
                                <i class="bi bi-box-arrow-up-right"></i> Voir la démo
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="{{ path('app_projects') }}" class="btn btn-outline-secondary">← Retour aux projets</a>
    </div>
</div>
{% endblock %}
